---
import { getCollection, getEntry, render } from 'astro:content';
import ServicesPage from '@dessy/dessyui/services-page';
import WellnessFooter from '@dessy/dessyui/footer';
import WellnessHeader from '@dessy/dessyui/site-header';
import SiteShell from '../layouts/SiteShell.astro';

const entry = await getEntry('services', 'index');

if (!entry) {
  throw new Error('Missing content entry: services/index');
}

const { Content } = await render(entry);
const servicePrograms = (await getCollection('servicePrograms')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<SiteShell title={entry.data.seoTitle} description={entry.data.seoDescription}>
  <WellnessHeader active="/services-programs" />
  <ServicesPage content={entry.data} servicePrograms={servicePrograms}>
    <Content />
  </ServicesPage>
  <WellnessFooter />
</SiteShell>
