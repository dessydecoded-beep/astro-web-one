---
import type { CollectionEntry } from 'astro:content';
import Section from '@dessy/daisyui/section';
import ServiceFeature from '../components/ServiceFeature.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { images } from '../data';

interface Props {
  content: CollectionEntry<'services'>['data'];
}

const { content } = Astro.props;

const services = content.services.map((service) => ({
  ...service,
  image: images[service.image as keyof typeof images],
}));
---

<main>
  <Section class="text-center">
    <Eyebrow>{content.hero.eyebrow}</Eyebrow>
    <h1 class="mx-auto mt-4 max-w-3xl font-serif text-5xl tracking-[-0.055em] text-balance md:text-7xl">{content.hero.heading}</h1>
    <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-base-content/65">
      {content.hero.text}
    </p>
  </Section>

  <div class="space-y-20 pb-8 md:space-y-28">
    {services.map((service) => (
      <Section class="py-0">
        <ServiceFeature {...service} />
      </Section>
    ))}
  </div>

  <Section>
    <div class="rounded-[2rem] border border-primary/10 bg-base-200 p-10 text-center organic-glow md:p-16">
      <h2 class="font-serif text-4xl tracking-[-0.035em]">{content.signature.heading}</h2>
      <div class="prose mx-auto mt-5 max-w-xl leading-8 text-base-content/65">
        <slot />
      </div>
      <div class="mt-7 inline-flex flex-wrap items-center justify-center gap-4 text-[0.72rem] font-bold uppercase tracking-[0.16em] text-primary">
        {content.signature.meta.map((item, index) => (
          <>
            {index > 0 && <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>}
            <span>{item}</span>
          </>
        ))}
      </div>
    </div>
  </Section>
</main>
