---
import Card from '@dessy/daisyui/card';
import Section from '@dessy/daisyui/section';
import BookingForm from '../components/BookingForm.astro';
import { images } from '../data';

const benefits = [
  ['psychology', 'Expert Guidance', 'Over 15 years of international expertise in holistic wellness and personal growth.'],
  ['self_improvement', 'Tailored Approach', 'Programs that align with your unique rhythm, goals, and current season of life.'],
  ['verified', 'Tranquil Space', 'A sanctuary designed to help you decompress and find immediate clarity.'],
];
---

<main>
  <section class="relative flex min-h-[400px] items-center justify-center overflow-hidden text-center">
    <img class="absolute inset-0 h-full w-full object-cover" src={images.stones} alt="River stones and a green leaf" />
    <div class="absolute inset-0 bg-base-100/65 backdrop-blur-[2px]"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-5">
      <h1 class="font-serif text-5xl tracking-[-0.055em] text-balance md:text-7xl">Begin Your Journey to Balance</h1>
      <p class="mt-5 text-lg italic leading-8 text-base-content/65">Professional guidance tailored to your personal path of serenity.</p>
    </div>
  </section>

  <Section>
    <div class="grid items-start gap-8 lg:grid-cols-12">
      <div class="space-y-8 lg:col-span-4">
        <Card class="bg-base-200">
          <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-accent">Get In Touch</p>
          <h2 class="mt-4 font-serif text-4xl tracking-[-0.035em]">Connect with us</h2>
          <div class="mt-8 space-y-6">
            <div class="flex gap-4"><span class="material-symbols-outlined text-primary">location_on</span><p><strong>Our Studio</strong><br /><span class="text-base-content/60">128 Serenity Lane, Ojai, CA</span></p></div>
            <div class="flex gap-4"><span class="material-symbols-outlined text-primary">mail</span><p><strong>Inquiries</strong><br /><span class="text-base-content/60">hello@serenepath.com</span></p></div>
            <div class="flex gap-4"><span class="material-symbols-outlined text-primary">schedule</span><p><strong>Hours</strong><br /><span class="text-base-content/60">Mon-Fri 8:00am-6:00pm</span></p></div>
          </div>
        </Card>
        <div class="relative h-[300px] overflow-hidden rounded-3xl border border-primary/10 organic-glow">
          <img class="h-full w-full object-cover" src={images.studio} alt="Minimalist yoga studio interior" loading="lazy" />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-base-100/90 to-transparent p-8">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-primary">Visit Our Sanctuary</p>
          </div>
        </div>
      </div>
      <Card class="bg-base-200 lg:col-span-8">
        <BookingForm />
      </Card>
    </div>
  </Section>

  <Section class="bg-secondary/35">
    <div class="grid gap-6 text-center md:grid-cols-3">
      {benefits.map(([icon, title, text]) => (
        <div class="p-8">
          <span class="material-symbols-outlined mb-4 text-4xl text-accent">{icon}</span>
          <h3 class="font-serif text-3xl">{title}</h3>
          <p class="mt-3 leading-7 text-base-content/65">{text}</p>
        </div>
      ))}
    </div>
  </Section>
</main>

