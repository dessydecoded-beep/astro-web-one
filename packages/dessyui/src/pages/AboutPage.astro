---
import type { CollectionEntry } from 'astro:content';
import Button from '@dessy/daisyui/button';
import Card from '@dessy/daisyui/card';
import Section from '@dessy/daisyui/section';
import Eyebrow from '../components/Eyebrow.astro';
import MatFrame from '../components/MatFrame.astro';
import { images } from '../data';

interface Props {
  content: CollectionEntry<'about'>['data'];
}

const { content } = Astro.props;
---

<main>
  <Section>
    <div class="grid items-center gap-12 md:grid-cols-2">
      <div>
        <Eyebrow>{content.hero.eyebrow}</Eyebrow>
        <h1 class="mt-5 font-serif text-5xl leading-[1.08] tracking-[-0.055em] text-balance md:text-7xl">{content.hero.heading}</h1>
        <p class="mt-6 text-lg leading-8 text-base-content/65">
          {content.hero.text}
        </p>
        <div class="mt-8 flex items-center gap-4">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-secondary text-secondary-content">
            <span class="material-symbols-outlined">psychology</span>
          </div>
          <div>
            <p class="font-bold">{content.hero.experienceLabel}</p>
            <p class="text-base-content/60">{content.hero.experienceText}</p>
          </div>
        </div>
      </div>
      <div class="relative">
        <div class="absolute -inset-4 -rotate-3 rounded-[2rem] border border-primary/10"></div>
        <MatFrame class="relative aspect-[4/5]" src={images.coach} alt={content.hero.imageAlt} />
      </div>
    </div>
  </Section>

  <Section class="bg-base-200">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <h2 class="font-serif text-4xl tracking-[-0.035em] md:text-5xl">{content.philosophyHeading}</h2>
      <p class="mt-4 text-base-content/65">{content.philosophyText}</p>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {content.philosophy.map((item, index) => (
        <Card class={index === 1 ? 'bg-primary text-primary-content' : ''}>
          <span class:list={['material-symbols-outlined mb-5 text-4xl', index === 1 ? 'text-primary-content' : 'text-primary']}>{item.icon}</span>
          <h3 class="font-serif text-3xl">{item.title}</h3>
          <p class:list={['mt-4 leading-7', index === 1 ? 'text-primary-content/85' : 'text-base-content/65']}>{item.text}</p>
          <p class:list={['mt-8 border-t pt-8 italic', index === 1 ? 'border-white/20' : 'border-primary/10 text-primary']}>{item.quote}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section>
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <h2 class="font-serif text-4xl tracking-[-0.035em]">{content.expertise.heading}</h2>
        <div class="prose mt-4 leading-7 text-base-content/65">
          <slot />
        </div>
      </div>
      <div class="grid gap-6 md:col-span-2 sm:grid-cols-2">
        {content.expertise.credentials.map((credential) => (
          <div class="flex gap-4">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">verified</span>
            <div>
              <p class="font-bold">{credential}</p>
              <p class="text-sm text-base-content/55">Professional practice</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section>
    <div class="relative overflow-hidden rounded-[2rem] bg-secondary p-10 text-center md:p-20">
      <span class="material-symbols-outlined absolute right-8 top-8 text-9xl text-secondary-content/10">spa</span>
      <div class="relative mx-auto max-w-2xl">
        <h2 class="font-serif text-5xl tracking-[-0.055em] text-balance">{content.cta.heading}</h2>
        <p class="mt-5 text-lg leading-8 text-secondary-content/75">{content.cta.text}</p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <Button href={content.cta.primaryHref}>{content.cta.primaryLabel}</Button>
          <Button href={content.cta.secondaryHref} variant="outline">{content.cta.secondaryLabel}</Button>
        </div>
      </div>
    </div>
  </Section>
</main>
