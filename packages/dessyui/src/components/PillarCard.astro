---
import Card from '@dessy/daisyui/card';

interface Props {
  accent?: 'primary' | 'secondary' | 'accent';
  checks?: readonly string[];
  icon: string;
  text: string;
  title: string;
}

const { accent = 'primary', checks = [], icon, text, title } = Astro.props;
const color = {
  primary: 'text-primary bg-primary/10',
  secondary: 'text-secondary-content bg-secondary',
  accent: 'text-accent bg-accent/10',
}[accent];
---

<Card class="h-full transition-transform duration-300 hover:-translate-y-1">
  <div class:list={['mb-6 flex h-16 w-16 items-center justify-center rounded-full', color]}>
    <span class="material-symbols-outlined text-3xl">{icon}</span>
  </div>
  <h3 class="font-serif text-3xl text-balance">{title}</h3>
  <p class="mt-4 leading-7 text-base-content/65">{text}</p>
  <ul class="mt-6 space-y-3">
    {checks.map((check) => (
      <li class="flex items-center gap-2 text-sm font-semibold text-base-content/75">
        <span class="material-symbols-outlined text-base text-primary">check_circle</span>
        {check}
      </li>
    ))}
  </ul>
</Card>
