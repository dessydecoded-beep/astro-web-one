---
import { siteConfig } from '../data';
---

<footer class="mt-24 border-t border-primary/10 bg-base-200 py-10">
  <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-5 px-5 text-center md:flex-row md:text-left">
    <a class="font-serif text-lg italic text-primary" href="/">{siteConfig.footerBrandName}</a>
    <nav class="flex flex-wrap justify-center gap-5 md:gap-8">
      {siteConfig.footerLinks.map((link) => (
        <a class="font-serif text-sm text-base-content/55 transition-colors hover:text-primary" href={link.href}>{link.label}</a>
      ))}
    </nav>
    <p class="font-serif text-sm text-base-content/55">© 2026 {siteConfig.footerBrandName}.</p>
  </div>
</footer>
