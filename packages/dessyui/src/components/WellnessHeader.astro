---
import Navbar from '@dessy/daisyui/navbar';
import { siteConfig } from '../data';

interface Props {
  active?: string;
}

const { active = '/' } = Astro.props;
---

<Navbar
  active={active}
  brand={siteConfig.brandName}
  ctaHref={siteConfig.cta.href}
  ctaLabel={siteConfig.cta.label}
  links={siteConfig.navLinks}
/>
