---
interface Props {
  as?: 'input' | 'textarea';
  class?: string;
  id: string;
  label: string;
  name?: string;
  placeholder?: string;
  rows?: number;
  type?: 'email' | 'number' | 'password' | 'search' | 'tel' | 'text' | 'url';
}

const {
  as = 'input',
  class: className = '',
  id,
  label,
  name = id,
  placeholder = '',
  rows = 5,
  type = 'text',
} = Astro.props as Props;

const controlClass = 'w-full rounded-none border-0 border-b-2 border-base-300 bg-base-100 px-0 py-3 text-base-content placeholder:text-base-content/35 focus:border-accent focus:outline-none focus:ring-0';
---

<label class:list={['form-control w-full gap-2', className]} for={id}>
  <span class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-base-content/60">{label}</span>
  {as === 'textarea' ? (
    <textarea class={controlClass} id={id} name={name} placeholder={placeholder} rows={rows}></textarea>
  ) : (
    <input class={controlClass} id={id} name={name} placeholder={placeholder} type={type} />
  )}
</label>
