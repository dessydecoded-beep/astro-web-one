---
interface Props {
  class?: string;
  containerClass?: string;
}

const { class: className = '', containerClass = '' } = Astro.props;
---

<section class:list={['py-16 md:py-24', className]}>
  <div class:list={['mx-auto w-full max-w-7xl px-5 sm:px-6 lg:px-8', containerClass]}>
    <slot />
  </div>
</section>

